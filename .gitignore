# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.pytest_cache/
.ruff_cache/

# Virtual environment
venv/
venv32/
.venv/
env/

# Build artifacts
build/
dist/
*.spec.bak

# Data & runtime (keep folder structure via .gitkeep, ignore contents)
data/*.db
data/*.db-shm
data/*.db-wal
data/logs/
data/uploads/
data/exports/
data/reports/
data/backups/

# Frontend (React/Vite) — node deps and build output are regenerated
frontend/node_modules/
frontend/dist/
frontend/.vite/
frontend/*.tsbuildinfo
npm-debug.log*

# Environment / secrets
# .env is intentionally tracked (bundled into the build); it must NOT contain a
# real password. Generated credentials and the session-cookie secret are never tracked:
credentials.txt
.session_secret
*.session_secret

# IDE
.vscode/
.idea/
*.swp
